{
  "manifest_version": 3,
  "name": "Banner to DocStar Bridge",
  "version": "1.0",
  "description": "Reads invoice numbers from Ellucian Banner and opens them in DocStar",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.wou.edu/*",
    "https://*.ec.wou.edu/*",
    "https://*.ec.wou.edu:*/*",
    "https://*.wou.education/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.wou.edu/*",
        "https://*.ec.wou.edu/*",
        "https://*.ec.wou.edu:*/*",
        "https://*.wou.education/*"
      ],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
